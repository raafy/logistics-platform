{
  "name": "@logistics/messaging",
  "version": "0.1.0",
  "private": true,
  "description": "Messaging framework: RabbitMQ client wrapper, transactional Outbox relay, DB-first idempotent consumer base. Infrastructure-agnostic contracts, concrete RMQ/Prisma adapters.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist .turbo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src --ext .ts"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15"
  },
  "dependencies": {
    "@logistics/contracts": "workspace:*",
    "@logistics/observability": "workspace:*",
    "amqp-connection-manager": "^4.1.14",
    "amqplib": "^0.10.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@types/amqplib": "^0.10.6",
    "@types/node": "^22.9.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
