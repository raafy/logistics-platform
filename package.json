{
  "name": "logistics-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Real-Time Logistics & Tracking System — event-driven NestJS microservices showcase",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "dev": "turbo run dev",
    "prisma:generate": "turbo run prisma:generate",
    "infra:up": "docker compose up -d postgres rabbitmq redis",
    "infra:down": "docker compose down -v",
    "infra:logs": "docker compose logs -f",
    "dlq:redrive": "pnpm --filter @logistics/dlq-redrive start",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  }
}
