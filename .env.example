# ─── Shared ────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug

# ─── PostgreSQL (single container, three logical DBs) ──────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_ROOT_USER=postgres
POSTGRES_ROOT_PASSWORD=postgres

# Per-service connection strings (each service sees ONLY its own DB)
ORDER_DATABASE_URL=postgresql://order_svc:order_pw@localhost:5432/order_db?schema=public
TRACKING_DATABASE_URL=postgresql://tracking_svc:tracking_pw@localhost:5432/tracking_db?schema=public
NOTIFICATION_DATABASE_URL=postgresql://notification_svc:notification_pw@localhost:5432/notification_db?schema=public

# ─── RabbitMQ ──────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=logistics.events
RABBITMQ_DLX=logistics.events.dlx

# ─── Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Services (ports) ──────────────────────────────────────────────────
ORDER_SERVICE_PORT=3001
TRACKING_SERVICE_PORT=3002
NOTIFICATION_SERVICE_PORT=3003

# ─── Inter-service URLs (for circuit-breaker composition endpoint) ─────
TRACKING_SERVICE_URL=http://localhost:3002

# ─── OpenTelemetry (optional) ──────────────────────────────────────────
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=logistics

# ─── Outbox tuning ─────────────────────────────────────────────────────
OUTBOX_POLL_INTERVAL_MS=500
OUTBOX_BATCH_SIZE=50
OUTBOX_MAX_ATTEMPTS=10
