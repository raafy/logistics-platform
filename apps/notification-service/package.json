{
  "name": "notification-service",
  "version": "0.1.0",
  "private": true,
  "description": "Consumer-only notification microservice",
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist .turbo node_modules/.prisma prisma/generated",
    "dev": "node --watch --enable-source-maps dist/main.js",
    "start": "node dist/main.js",
    "lint": "eslint src test --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push"
  },
  "dependencies": {
    "@logistics/contracts": "workspace:*",
    "@logistics/messaging": "workspace:*",
    "@logistics/observability": "workspace:*",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@prisma/client": "^5.22.0",
    "nestjs-pino": "^4.3.0",
    "pino-pretty": "^11.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@logistics/testing": "workspace:*",
    "@types/amqplib": "^0.10.6",
    "@types/node": "^22.9.0",
    "amqplib": "^0.10.5",
    "prisma": "^5.22.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
