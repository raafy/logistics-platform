{
  "name": "@logistics/tracking-service",
  "version": "0.1.0",
  "private": true,
  "description": "Tracking Service NestJS microservice with layered architecture",
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist .turbo prisma/generated",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "prisma:generate": "prisma generate",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@logistics/contracts": "workspace:*",
    "@logistics/messaging": "workspace:*",
    "@logistics/observability": "workspace:*",
    "@nestjs/common": "^10.4.22",
    "@nestjs/core": "^10.4.22",
    "@nestjs/platform-express": "^10.4.22",
    "@nestjs/swagger": "^7.4.2",
    "@prisma/client": "^6.7.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "nestjs-pino": "^4.6.1",
    "pino-pretty": "^13.1.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.22",
    "@types/node": "^22.9.0",
    "@types/supertest": "^6.0.3",
    "prisma": "^6.7.0",
    "tslib": "^2.8.1",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  }
}
